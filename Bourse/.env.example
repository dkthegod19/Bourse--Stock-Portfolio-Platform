# Copy to .env and adjust. All values have sane local defaults in config.go.

PORT=8080

# Postgres connection string.
DATABASE_URL=postgres://bourse:bourse@localhost:5432/bourse?sslmode=disable

# Redis connection string.
REDIS_URL=redis://localhost:6379/0

# Market data: "stub" needs no key and runs fully offline (deterministic moving
# prices). Set to "finnhub" + a free API key from https://finnhub.io to use real
# market prices.
MARKETDATA_PROVIDER=stub
MARKETDATA_API_KEY=

# Default rate limit applied to API keys with no explicit config.
DEFAULT_RATE=10
DEFAULT_BURST=20

# Job visibility timeout (seconds) and quote cache TTL (seconds).
LEASE_SECONDS=30
QUOTE_TTL_SECONDS=10
